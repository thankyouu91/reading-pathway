<!DOCTYPE html>
<html lang="<%= lang %>" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO Primary Meta Tags -->
    <title>Reading Pathway | Chương Trình Đọc Hiểu & Pre-IELTS - Trophy9 & Achieve3000</title>
    <meta name="description" content="Chương trình rèn luyện Đọc Hiểu & Pre-IELTS từ Mầm Non đến Đại Học với nền tảng Trophy9 (54 cấp độ, 198 Readers) và Achieve3000 (Lexile) theo chuẩn Mỹ CCSS.">
    <meta name="keywords" content="Reading Pathway, Trophy9, Achieve3000, đọc hiểu, Pre-IELTS, IELTS, tiếng Anh trẻ em, Phonics, Lexile, CCSS, học tiếng Anh, reading comprehension, English for kids">
    <meta name="author" content="Trophy Learning, Inc.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= typeof siteUrl !== 'undefined' ? siteUrl : 'https://readingpathway.up.railway.app' %>">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= typeof siteUrl !== 'undefined' ? siteUrl : 'https://readingpathway.up.railway.app' %>">
    <meta property="og:title" content="Reading Pathway | Chương Trình Đọc Hiểu Toàn Diện - Trophy9 & Achieve3000">
    <meta property="og:description" content="Lộ trình đọc hiểu & Pre-IELTS từ Mầm Non đến Đại Học. 54 cấp độ, 198 Readers, 9 hoạt động tương tác theo chuẩn Mỹ CCSS & Lexile.">
    <meta property="og:image" content="<%= typeof siteUrl !== 'undefined' ? siteUrl : '' %>/images/og-reading-pathway.jpg">
    <meta property="og:locale" content="vi_VN">
    <meta property="og:site_name" content="Reading Pathway">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Reading Pathway | Đọc Hiểu & Pre-IELTS - Trophy9 & Achieve3000">
    <meta name="twitter:description" content="Lộ trình đọc hiểu toàn diện từ Mầm Non đến Đại Học với Trophy9 và Achieve3000 theo chuẩn Mỹ.">
    <meta name="twitter:image" content="<%= typeof siteUrl !== 'undefined' ? siteUrl : '' %>/images/og-reading-pathway.jpg">

    <!-- Structured Data - JSON-LD -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "EducationalOrganization",
        "name": "Reading Pathway",
        "description": "Chương trình rèn luyện Đọc Hiểu & Pre-IELTS từ Mầm Non đến Đại Học với Trophy9 và Achieve3000",
        "url": "<%= typeof siteUrl !== 'undefined' ? siteUrl : 'https://readingpathway.up.railway.app' %>",
        "logo": "<%= typeof siteUrl !== 'undefined' ? siteUrl : '' %>/images/logo-trophy9.svg",
        "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+84-345-037-595",
            "contactType": "customer service",
            "availableLanguage": "Vietnamese"
        },
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Ho Chi Minh City",
            "addressCountry": "VN"
        },
        "sameAs": [
            "https://www.trophy9.com",
            "https://www.trophy9.com.vn"
        ]
    }
    </script>

    <!-- Course Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Reading Pathway - Chương Trình Đọc Hiểu Toàn Diện",
        "description": "Lộ trình đọc hiểu tiếng Anh từ Mầm Non đến Đại Học, kết hợp Trophy9 (54 cấp độ) và Achieve3000 (Lexile) theo chuẩn CCSS Mỹ",
        "provider": {
            "@type": "Organization",
            "name": "Trophy Learning, Inc.",
            "url": "https://www.trophy9.com"
        },
        "educationalLevel": ["Preschool", "Elementary School", "Middle School", "High School", "University"],
        "inLanguage": "en",
        "teaches": ["Reading Comprehension", "Phonics", "IELTS Preparation", "Academic English"],
        "numberOfCredits": "54",
        "hasCourseInstance": [
            {
                "@type": "CourseInstance",
                "name": "Trophy9 WALK (T1-T2)",
                "courseMode": "blended",
                "educationalLevel": "Preschool - Elementary"
            },
            {
                "@type": "CourseInstance",
                "name": "Trophy9 RUN (T3-T4)",
                "courseMode": "blended",
                "educationalLevel": "Elementary - Middle School"
            },
            {
                "@type": "CourseInstance",
                "name": "Trophy9 SPRINT (T5-T6)",
                "courseMode": "blended",
                "educationalLevel": "Middle School"
            },
            {
                "@type": "CourseInstance",
                "name": "Achieve3000 Empower3000",
                "courseMode": "online",
                "educationalLevel": "High School"
            }
        ]
    }
    </script>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "Trophy9 phù hợp cho độ tuổi nào?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Trophy9 phù hợp cho trẻ từ Mẫu Giáo đến Lớp 9 (3-15 tuổi), với 54 cấp độ từ Phonics cơ bản đến đọc hiểu nâng cao theo chuẩn CCSS Mỹ."
                }
            },
            {
                "@type": "Question",
                "name": "Achieve3000 khác Trophy9 như thế nào?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Achieve3000 dành cho học sinh THPT đến Đại Học (15+ tuổi), sử dụng chỉ số Lexile để cá nhân hóa nội dung đọc hiểu học thuật, chuẩn bị cho IELTS 5.0-8.0+."
                }
            },
            {
                "@type": "Question",
                "name": "Chương trình có giúp chuẩn bị IELTS không?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Có. Lộ trình bao gồm Pre-IELTS (3.0-4.5) với Trophy9 và IELTS Standard đến Advanced (5.0-8.0+) với Achieve3000, rèn đọc hiểu học thuật và tư duy phản biện."
                }
            }
        ]
    }
    </script>

    <!-- Performance: Preconnect & Preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://lottie.host">
    <link rel="preload" href="styles.css" as="style">
    <link rel="preload" href="premium.css" as="style">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Stylesheets -->
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="premium.css">

    <!-- Lottie Player (deferred) -->
    <script src="https://unpkg.com/@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs" type="module"></script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📖</text></svg>">
</head>
<body>
<!-- Loading Screen -->
<div class="loading-screen" id="loadingScreen">
    <div class="loading-book">
        <div class="book-page page-left"></div>
        <div class="book-page page-right"></div>
        <div class="book-spine"></div>
    </div>
    <p class="loading-text">Reading Pathway</p>
    <p class="loading-subtext">CDIMEX EDUCATION SOLUTIONS</p>
</div>

<% const g = (section, key, fallback) => { try { return c[section] && c[section][key] ? c[section][key] : fallback || ''; } catch(e) { return fallback || ''; } }; %>
<% const list = (section, key) => { try { return JSON.parse(g(section, key, '[]')); } catch(e) { return []; } }; %>

<!-- Navigation -->
<nav class="navbar" id="navbar">
    <div class="container nav-container">
        <a href="/" class="logo">
            <span class="logo-icon">📖</span>
            <span class="logo-text">Reading <span class="highlight">Pathway</span></span>
        </a>
        <ul class="nav-links" id="navLinks">
            <li><a href="#program"><%= g('nav','menu_program','Chương Trình') %></a></li>
            <li><a href="#pathway"><%= g('nav','menu_pathway','Lộ Trình') %></a></li>
            <li><a href="#trophy9">Trophy9</a></li>
            <li><a href="#achieve3000">Achieve3000</a></li>
            <li><a href="#ielts">Pre-IELTS</a></li>
            <li><a href="#schools"><%= g('nav','menu_schools','Trường Học') %></a></li>
            <li><a href="#contact" class="btn-nav"><%= g('nav','cta_button','Đăng Ký Ngay') %></a></li>
        </ul>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

<!-- Hero Section - Interactive -->
<section class="hero" id="hero">
    <!-- Animated particles background -->
    <canvas id="heroParticles" class="hero-particles"></canvas>

    <!-- Mouse-follow glow -->
    <div class="hero-glow" id="heroGlow"></div>

    <div class="container hero-content">
        <div class="hero-text">
            <div class="hero-badge"><%= g('hero','badge') %></div>
            <h1 class="hero-title-animated">
                <span class="title-word" style="--delay:0"><%= g('hero','heading') %></span>
                <span class="title-word gradient-text" style="--delay:1"><%= g('hero','heading_highlight') %></span>
                <span class="title-word" style="--delay:2"><%= g('hero','heading_suffix') %></span>
            </h1>
            <p class="hero-subtitle"><%= g('hero','subtitle') %></p>
            <div class="hero-logos">
                <img src="<%= g('hero','logo_trophy9','images/logo-trophy9.svg') %>" alt="Trophy9" class="hero-logo-img">
                <span class="hero-logo-divider">+</span>
                <img src="<%= g('hero','logo_achieve3000','images/logo-achieve3000.svg') %>" alt="Achieve3000" class="hero-logo-img">
            </div>
            <div class="hero-stats">
                <% for (let i = 1; i <= 4; i++) { %>
                <div class="stat" style="--delay:<%= i %>">
                    <span class="stat-number"><%= g('hero','stat_'+i+'_number') %></span>
                    <span class="stat-label"><%= g('hero','stat_'+i+'_label') %></span>
                </div>
                <% } %>
            </div>
            <div class="hero-cta">
                <a href="#contact" class="btn btn-primary btn-lg btn-glow"><%= g('hero','cta_primary') %></a>
                <a href="#pathway" class="btn btn-outline btn-lg"><%= g('hero','cta_secondary') %></a>
            </div>
        </div>
        <div class="hero-visual">
            <!-- Interactive Journey Path -->
            <div class="journey-path" id="journeyPath">
                <svg class="journey-line" viewBox="0 0 400 500" fill="none">
                    <path id="journeyPathSvg" d="M200 30 C200 30,80 100,80 140 C80 180,320 200,320 240 C320 280,80 320,80 360 C80 400,200 440,200 470" stroke="url(#journeyGrad)" stroke-width="3" stroke-dasharray="8 6" fill="none" opacity="0.4"/>
                    <defs>
                        <linearGradient id="journeyGrad" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#10B981"/>
                            <stop offset="33%" stop-color="#0056A6"/>
                            <stop offset="66%" stop-color="#C8372D"/>
                            <stop offset="100%" stop-color="#7C3AED"/>
                        </linearGradient>
                    </defs>
                </svg>

                <% const journeyCards = [
                    { i: 1, icon: '🌒', color: '#10B981', x: '55%', y: '2%' },
                    { i: 2, icon: '📖', color: '#0056A6', x: '8%', y: '23%' },
                    { i: 3, icon: '🎯', color: '#F59E0B', x: '55%', y: '45%' },
                    { i: 4, icon: '🎓', color: '#7C3AED', x: '12%', y: '70%' }
                ]; %>
                <% journeyCards.forEach(jc => { %>
                <div class="journey-card" data-card="<%= jc.i %>" style="left:<%= jc.x %>;top:<%= jc.y %>;--card-color:<%= jc.color %>">
                    <div class="journey-card-inner">
                        <div class="journey-card-front">
                            <span class="journey-icon"><%= jc.icon %></span>
                            <span class="journey-label"><%= g('hero','card_'+jc.i+'_label') %></span>
                        </div>
                        <div class="journey-card-back">
                            <span class="journey-sub"><%= g('hero','card_'+jc.i+'_sub') %></span>
                        </div>
                    </div>
                    <div class="journey-pulse"></div>
                </div>
                <% }); %>

                <!-- Animated traveler dot -->
                <div class="journey-traveler" id="journeyTraveler"></div>
            </div>
        </div>
    </div>
    <div class="hero-wave">
        <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 60L48 52C96 44 192 28 288 24C384 20 480 28 576 40C672 52 768 68 864 72C960 76 1056 68 1152 56C1248 44 1344 28 1392 20L1440 12V120H1392C1344 120 1248 120 1152 120C1056 120 960 120 864 120C768 120 672 120 576 120C480 120 384 120 288 120C192 120 96 120 48 120H0V60Z" fill="white"/>
        </svg>
    </div>
    <!-- Scroll indicator -->
    <div class="scroll-indicator" id="scrollIndicator">
        <div class="scroll-mouse"><div class="scroll-dot"></div></div>
        <span>Cuon xuong</span>
    </div>
</section>

<!-- Program Overview -->
<section class="section" id="program">
    <div class="container">
        <div class="section-header">
            <span class="section-tag"><%= g('program','tag') %></span>
            <h2><%= g('program','heading') %></h2>
            <p><%= g('program','description') %></p>
        </div>
        <div class="program-grid">
            <div class="program-card trophy-card">
                <div class="program-card-header">
                    <img src="images/logo-trophy9.svg" alt="Trophy9" class="program-logo">
                    <span class="program-age"><%= g('program','trophy_age') %></span>
                </div>
                <h3><%= g('program','trophy_heading') %></h3>
                <p><%= g('program','trophy_description') %></p>
                <ul class="feature-list">
                    <% list('program','trophy_features').forEach(item => { %>
                    <li><span class="check">&#10003;</span> <%= item %></li>
                    <% }); %>
                </ul>
                <a href="<%= g('program','trophy_url','https://www.trophy9.com/') %>" target="_blank" class="btn btn-trophy"><%= g('program','trophy_button') %></a>
            </div>
            <div class="program-card achieve-card">
                <div class="program-card-header">
                    <img src="images/logo-achieve3000.svg" alt="Achieve3000" class="program-logo">
                    <span class="program-age"><%= g('program','achieve_age') %></span>
                </div>
                <h3><%= g('program','achieve_heading') %></h3>
                <p><%= g('program','achieve_description') %></p>
                <ul class="feature-list">
                    <% list('program','achieve_features').forEach(item => { %>
                    <li><span class="check">&#10003;</span> <%= item %></li>
                    <% }); %>
                </ul>
                <a href="<%= g('program','achieve_url') %>" target="_blank" class="btn btn-achieve"><%= g('program','achieve_button') %></a>
            </div>
        </div>
    </div>
</section>

<!-- Trophy9 - 9 Activities -->
<section class="section section-trophy-blue" id="trophy9">
    <div class="container">
        <div class="section-header light">
            <img src="images/logo-trophy9.svg" alt="Trophy9" class="section-logo-img trophy-logo-white">
            <h2><%= g('activities','heading') %></h2>
            <p><%= g('activities','description') %></p>
        </div>
        <div class="activities-grid">
            <% const actLotties = [
              'https://lottie.host/2a81dc80-7e9a-4c79-b64f-1d2c5e3f4a5b/book.json',
              'https://lottie.host/3b92ed91-8fab-5d8a-a75e-2e3d6f4g5b6c/quiz.json',
              'https://lottie.host/4ca3fe02-9gbc-6e9b-b86f-3f4e7g5h6c7d/vocab.json',
              'https://lottie.host/5db40f13-ag0d-7fac-c97g-4g5f8h6i7d8e/dictation.json',
              'https://lottie.host/6ec51024-bh1e-80bd-da8h-5h6g9i7j8e9f/shadow.json',
              'https://lottie.host/7fd62135-ci2f-91ce-eb9i-6i7h0j8k9f0g/story.json',
              'https://lottie.host/80e73246-dj3g-a2df-fc0j-7j8i1k9l0g1h/roleplay.json',
              'https://lottie.host/91f84357-ek4h-b3eg-gd1k-8k9j2l0m1h2i/grammar.json',
              'https://lottie.host/a2g95468-fl5i-c4fh-he2l-9l0k3m1n2i3j/report.json'
            ]; %>
            <% for (let i = 1; i <= 9; i++) { %>
            <div class="activity-card">
                <div class="activity-number"><%= i %></div>
                <h4><%= g('activities','activity_'+i+'_title') %></h4>
                <p><%= g('activities','activity_'+i+'_desc') %></p>
            </div>
            <% } %>
        </div>
    </div>
</section>

<!-- Trophy9 Levels T1-T6 -->
<section class="section" id="trophy9-levels">
    <div class="container">
        <div class="section-header">
            <span class="section-tag trophy-tag"><%= g('levels','tag','Trophy9 Levels') %></span>
            <h2><%= g('levels','heading') %></h2>
            <p><%= g('levels','description') %></p>
        </div>
        <div class="trophy-levels">
            <% const groups = [
                { label: g('levels','group_1_label'), name: g('levels','group_1_name'), css: 'walk', levels: ['t1','t2'], badge: 'walk-badge' },
                { label: g('levels','group_2_label'), name: g('levels','group_2_name'), css: 'run', levels: ['t3','t4'], badge: 'run-badge' },
                { label: g('levels','group_3_label'), name: g('levels','group_3_name'), css: 'sprint', levels: ['t5','t6'], badge: 'sprint-badge' }
            ]; %>
            <% groups.forEach(grp => { %>
            <div class="level-group">
                <div class="level-group-header <%= grp.css %>">
                    <span class="level-group-label"><%= grp.label %></span>
                    <span class="level-group-name"><%= grp.name %></span>
                </div>
                <div class="level-cards-row">
                    <% grp.levels.forEach(lv => { %>
                    <div class="level-card">
                        <div class="level-badge <%= grp.badge %>"><%= lv.toUpperCase() %></div>
                        <h4><%= g('levels', lv+'_title') %></h4>
                        <p><%= g('levels', lv+'_desc') %></p>
                        <div class="level-meta">
                            <span>9 Steps</span>
                            <span>4 Readers + 1 Workbook</span>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Learning Pathway -->
<section class="section section-gray" id="pathway">
    <!-- Floating background decorations -->
    <div class="pathway-decorations">
        <div class="deco deco-book-1">📚</div>
        <div class="deco deco-star-1">⭐</div>
        <div class="deco deco-pencil">✏️</div>
        <div class="deco deco-globe">🌍</div>
        <div class="deco deco-star-2">💡</div>
        <div class="deco deco-hat">🎓</div>
        <div class="deco deco-abc">🔤</div>
        <div class="deco deco-rocket">🚀</div>
    </div>
    <div class="container">
        <div class="section-header">
            <span class="section-tag"><%= g('pathway','tag') %></span>
            <h2><%= g('pathway','heading') %></h2>
            <p><%= g('pathway','description') %></p>
        </div>
        <div class="pathway-timeline">
            <% const stages = [
                { n: 1, icon: '🌱', css: 'kindergarten', dotCss: '', lineCss: '',
                  illus: 'https://stories.freepiklabs.com/storage/4524/book-lover_Artboard-1.svg' },
                { n: 2, icon: '📖', css: 'primary', dotCss: '', lineCss: '',
                  illus: 'https://stories.freepiklabs.com/storage/16533/472-Learning_Artboard-1.svg' },
                { n: 3, icon: '🎯', css: 'secondary', dotCss: '', lineCss: '',
                  illus: 'https://stories.freepiklabs.com/storage/34149/learning-01.svg' }
            ]; %>
            <% stages.forEach(s => { %>
            <div class="pathway-stage" data-stage="<%= s.n %>">
                <div class="stage-marker">
                    <div class="stage-dot <%= s.dotCss %>"></div>
                    <div class="stage-line <%= s.lineCss %>"></div>
                </div>
                <div class="stage-content">
                    <div class="stage-card <%= s.css %>">
                        <div class="stage-illustration"><img src="<%= s.illus %>" alt="illustration" loading="lazy"></div>
                        <div class="stage-header">
                            <span class="stage-icon"><%= s.icon %></span>
                            <div>
                                <h3><%= g('pathway','stage_'+s.n+'_title') %></h3>
                                <span class="stage-platform"><%= g('pathway','stage_'+s.n+'_platform') %></span>
                            </div>
                        </div>
                        <div class="stage-body">
                            <div class="stage-goals">
                                <h4><%= lang === 'en' ? 'Goals' : lang === 'lo' ? 'ເປົ້າໝາຍ' : lang === 'km' ? 'គោលដៅ' : 'Mục Tiêu' %></h4>
                                <ul>
                                    <% list('pathway','stage_'+s.n+'_goals').forEach(goal => { %>
                                    <li><%= goal %></li>
                                    <% }); %>
                                </ul>
                            </div>
                            <div class="stage-details">
                                <div class="detail-chip"><strong>Lexile:</strong> <%= g('pathway','stage_'+s.n+'_lexile') %></div>
                                <div class="detail-chip"><strong>CEFR:</strong> <%= g('pathway','stage_'+s.n+'_cefr') %></div>
                                <div class="detail-chip"><strong><%= g('pathway','stage_'+s.n+'_ielts') ? 'IELTS:' : (lang==='en'?'Skills:':'Kỹ Năng:') %></strong> <%= g('pathway','stage_'+s.n+'_ielts') || g('pathway','stage_'+s.n+'_skills') %></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>

            <!-- Bridge -->
            <div class="pathway-bridge">
                <div class="bridge-content">
                    <div class="bridge-icon">🔄</div>
                    <div class="bridge-text">
                        <strong><%= g('pathway','bridge_title') %></strong>
                        <p><%= g('pathway','bridge_desc') %></p>
                    </div>
                </div>
            </div>

            <% const stagesAchieve = [
                { n: 4, icon: '🏆', css: 'highschool',
                  illus: 'https://stories.freepiklabs.com/storage/34549/Online-Learning_Mesa-de-trabajo-1.svg' },
                { n: 5, icon: '🎓', css: 'university',
                  illus: 'https://stories.freepiklabs.com/storage/1548/63-Graduation_Artboard-1.svg' }
            ]; %>
            <% stagesAchieve.forEach((s, idx) => { %>
            <div class="pathway-stage" data-stage="<%= s.n %>">
                <div class="stage-marker">
                    <div class="stage-dot achieve-dot"></div>
                    <% if (idx === 0) { %><div class="stage-line achieve-line"></div><% } %>
                </div>
                <div class="stage-content">
                    <div class="stage-card <%= s.css %>">
                        <div class="stage-illustration"><img src="<%= s.illus %>" alt="illustration" loading="lazy"></div>
                        <div class="stage-header">
                            <span class="stage-icon"><%= s.icon %></span>
                            <div>
                                <h3><%= g('pathway','stage_'+s.n+'_title') %></h3>
                                <span class="stage-platform achieve-label"><%= g('pathway','stage_'+s.n+'_platform') %></span>
                            </div>
                        </div>
                        <div class="stage-body">
                            <div class="stage-goals">
                                <h4><%= lang === 'en' ? 'Goals' : lang === 'lo' ? 'ເປົ້າໝາຍ' : lang === 'km' ? 'គោលដៅ' : 'Mục Tiêu' %></h4>
                                <ul>
                                    <% list('pathway','stage_'+s.n+'_goals').forEach(goal => { %>
                                    <li><%= goal %></li>
                                    <% }); %>
                                </ul>
                            </div>
                            <div class="stage-details">
                                <div class="detail-chip"><strong>Lexile:</strong> <%= g('pathway','stage_'+s.n+'_lexile') %></div>
                                <div class="detail-chip"><strong>CEFR:</strong> <%= g('pathway','stage_'+s.n+'_cefr') %></div>
                                <div class="detail-chip"><strong>IELTS:</strong> <%= g('pathway','stage_'+s.n+'_ielts') %></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Achieve3000 Detail -->
<section class="section section-dark" id="achieve3000">
    <div class="container">
        <div class="section-header light">
            <img src="images/logo-achieve3000.svg" alt="Achieve3000" class="section-logo-img achieve-logo-white">
            <h2><%= g('achieve3000','heading') %></h2>
            <p><%= g('achieve3000','description') %></p>
        </div>
        <div class="achieve-features">
            <div class="achieve-feature-main">
                <div class="lexile-meter">
                    <div class="meter-label"><%= lang === 'en' ? 'Lexile Score' : 'Chỉ Số Lexile' %></div>
                    <div class="meter-bar"><div class="meter-fill" id="lexileMeter"></div></div>
                    <div class="meter-scale"><span>200L</span><span>600L</span><span>1000L</span><span>1400L+</span></div>
                </div>
                <h3><%= g('achieve3000','lexile_heading') %></h3>
                <p><%= g('achieve3000','lexile_description') %></p>
            </div>
            <div class="achieve-feature-grid">
                <% const achieveIcons = ['📰','📈','🎯','💼']; %>
                <% for (let i = 1; i <= 4; i++) { %>
                <div class="achieve-card">
                    <div class="achieve-card-icon"><%= achieveIcons[i-1] %></div>
                    <h4><%= g('achieve3000','feature_'+i+'_title') %></h4>
                    <p><%= g('achieve3000','feature_'+i+'_desc') %></p>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</section>

<!-- Pre-IELTS Section -->
<section class="section" id="ielts">
    <div class="container">
        <div class="section-header">
            <span class="section-tag ielts-tag"><%= g('ielts','tag') %></span>
            <h2><%= g('ielts','heading') %></h2>
            <p><%= g('ielts','description') %></p>
        </div>
        <div class="ielts-pathway">
            <% for (let i = 1; i <= 4; i++) { %>
            <div class="ielts-stage">
                <div class="ielts-level">
                    <span class="ielts-score"><%= g('ielts','stage_'+i+'_score') %></span>
                    <span class="ielts-name"><%= g('ielts','stage_'+i+'_name') %></span>
                </div>
                <div class="ielts-detail">
                    <p><%= g('ielts','stage_'+i+'_desc') %></p>
                    <div class="ielts-skills">
                        <% list('ielts','stage_'+i+'_skills').forEach(skill => { %>
                        <span><%= skill %></span>
                        <% }); %>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</section>

<!-- Comparison Table -->
<section class="section section-gray" id="compare">
    <div class="container">
        <div class="section-header">
            <span class="section-tag"><%= g('comparison','tag') %></span>
            <h2><%= g('comparison','heading') %></h2>
            <p><%= g('comparison','description') %></p>
        </div>
        <div class="comparison-table-wrapper">
            <table class="comparison-table">
                <thead>
                    <tr>
                        <th><%= lang === 'en' ? 'Criteria' : lang === 'lo' ? 'ເກນ' : lang === 'km' ? 'លក្ខណៈវិនិច្ឆ័យ' : 'Tiêu Chí' %></th>
                        <th class="trophy-col">Trophy9</th>
                        <th class="achieve-col">Achieve3000</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (let i = 1; i <= 6; i++) { %>
                    <tr>
                        <td><%= g('comparison','row_'+i+'_label') %></td>
                        <td><%= g('comparison','row_'+i+'_trophy') %></td>
                        <td><%= g('comparison','row_'+i+'_achieve') %></td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- B2B Schools Section -->
<section class="section section-b2b" id="schools">
    <div class="container">
        <div class="section-header">
            <span class="section-tag b2b-tag"><%= g('b2b','tag') %></span>
            <h2><%= g('b2b','heading') %></h2>
            <p><%= g('b2b','description') %></p>
        </div>
        <div class="b2b-grid">
            <% for (let i = 1; i <= 4; i++) { %>
            <div class="b2b-card">
                <div class="b2b-icon">
                    <% const b2bColors = ['#E8F4FD','#FFF1F0','#F0FDF4','#F5F3FF']; %>
                    <% const b2bFills = ['#0056A6','#C8372D','#10B981','#7C3AED']; %>
                    <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="10" fill="<%= b2bColors[i-1] %>"/><circle cx="20" cy="20" r="8" fill="<%= b2bFills[i-1] %>"/></svg>
                </div>
                <h3><%= g('b2b','card_'+i+'_title') %></h3>
                <p><%= g('b2b','card_'+i+'_desc') %></p>
                <ul class="b2b-features">
                    <% list('b2b','card_'+i+'_features').forEach(f => { %>
                    <li><%= f %></li>
                    <% }); %>
                </ul>
            </div>
            <% } %>
        </div>

        <div class="testing-framework">
            <h3><%= g('b2b','testing_heading') %></h3>
            <div class="testing-timeline">
                <% const testColors = ['placement','module','midterm','final']; %>
                <% for (let i = 1; i <= 4; i++) { %>
                <div class="test-step">
                    <div class="test-icon <%= testColors[i-1] %>"><%= ['P','M','G','F'][i-1] %></div>
                    <div class="test-info">
                        <h4><%= g('b2b','test_'+i+'_title') %></h4>
                        <p><%= g('b2b','test_'+i+'_time') %></p>
                        <span class="test-desc"><%= g('b2b','test_'+i+'_desc') %></span>
                    </div>
                </div>
                <% if (i < 4) { %><div class="test-arrow">→</div><% } %>
                <% } %>
            </div>
        </div>

        <div class="b2b-cta">
            <p><%= g('b2b','cta_text') %></p>
            <a href="#contact" class="btn btn-primary btn-lg"><%= g('b2b','cta_button') %></a>
        </div>
    </div>
</section>

<!-- CTA / Contact -->
<section class="section section-cta" id="contact">
    <div class="container">
        <div class="cta-content">
            <div class="cta-text">
                <h2><%= g('contact','heading') %></h2>
                <p><%= g('contact','description') %></p>
                <ul class="cta-benefits">
                    <% for (let i = 1; i <= 4; i++) { %>
                    <li>&#10003; <%= g('contact','benefit_'+i) %></li>
                    <% } %>
                </ul>
                <div class="cta-logos">
                    <img src="images/logo-trophy9.svg" alt="Trophy9" class="cta-logo-img">
                    <img src="images/logo-achieve3000.svg" alt="Achieve3000" class="cta-logo-img">
                </div>
            </div>
            <div class="cta-form">
                <form id="contactForm">
                    <input type="hidden" name="lang" value="<%= lang %>">
                    <div class="form-group">
                        <label for="parentName">Tên Trường/ Trung Tâm</label>
                        <input type="text" id="parentName" name="parentName" placeholder="Nhập tên trường hoặc trung tâm" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Số Điện Thoại</label>
                        <input type="tel" id="phone" name="phone" placeholder="0xxx xxx xxx" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="email@example.com" required>
                    </div>
                    <div class="form-group">
                        <label for="childAge">Cấp</label>
                        <select id="childAge" name="childAge" required>
                            <option value="">Chọn cấp</option>
                            <option value="cap1">Cấp 1</option>
                            <option value="cap2">Cấp 2</option>
                            <option value="cap3">Cấp 3</option>
                            <option value="liencap">Liên Cấp</option>
                            <option value="daihoc">Đại Học</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="goal">Mục Tiêu</label>
                        <select id="goal" name="goal">
                            <option value="">Chọn mục tiêu</option>
                            <option value="reading">Rèn Đọc Hiểu</option>
                            <option value="preielts">Pre-IELTS</option>
                            <option value="ielts">IELTS</option>
                            <option value="academic">Học Thuật</option>
                            <option value="all">Tất Cả</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block"><%= g('contact','form_button') %></button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col">
                <div class="logo footer-logo">
                    <span class="logo-icon">📖</span>
                    <span class="logo-text">Reading <span class="highlight">Pathway</span></span>
                </div>
                <p><%= g('footer','description') %></p>
                <div class="footer-logos">
                    <img src="images/logo-trophy9.svg" alt="Trophy9" class="footer-logo-img">
                    <img src="images/logo-achieve3000.svg" alt="Achieve3000" class="footer-logo-img">
                </div>
            </div>
            <div class="footer-col">
                <h4><%= g('footer','col2_title') %></h4>
                <ul>
                    <li><a href="#trophy9">Trophy9</a></li>
                    <li><a href="#achieve3000">Achieve3000</a></li>
                    <li><a href="#ielts">Pre-IELTS & IELTS</a></li>
                    <li><a href="#pathway"><%= g('pathway','tag') %></a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4><%= g('footer','col3_title') %></h4>
                <ul>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Guide</a></li>
                    <li><a href="#">Privacy</a></li>
                    <li><a href="#">Terms</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4><%= g('footer','col4_title') %></h4>
                <ul>
                    <li>Zalo/ Whatsapp: <%= g('footer','contact_zalo') %></li>
                    <li>Email: <%= g('footer','contact_email') %></li>
                    <li>Web: <%= g('footer','contact_website') %></li>
                    <li><%= g('footer','contact_address') %></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; <%= g('footer','copyright') %></p>
        </div>
    </div>
</footer>

