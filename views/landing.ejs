</section>

<!-- Photo divider -->
<div class="photo-divider">
    <img src="/images/generated/divider-students.jpg" alt="Students" loading="lazy">
    <div class="photo-divider-overlay"></div>
</div>

<!-- Solutions for Schools - Strategic Value -->
<section class="section section-solutions" id="solutions">
    <div class="container">
        <div class="section-header">
            <span class="section-tag solutions-tag">Giải Pháp Cho Trường Học & Trung Tâm</span>
            <h2>K9 - K12 - Đại Học, các cấp</h2>
            <p>Giải pháp đọc hiểu liên cấp duy nhất theo Đề án 2371/QĐ-TTg - Đưa tiếng Anh thành ngôn ngữ thứ hai</p>
        </div>

        <!-- Problem → Solution flow -->
        <div class="solutions-problem-box">
            <div class="problem-header">
                <span class="problem-icon">⚠️</span>
                <h3>Thách Thức Hiện Tại Của Trường Học</h3>
            </div>
            <div class="problem-grid">
                <div class="problem-item">
                    <span>📉</span>
                    <p>Học sinh thiếu nền tảng Phonics, đọc được nhưng <strong>không hiểu</strong></p>
                </div>
                <div class="problem-item">
                    <span>🔄</span>
                    <p>Chương trình rời rạc, <strong>không liên tục</strong> giữa các cấp</p>
                </div>
                <div class="problem-item">
                    <span>📊</span>
                    <p>Không có <strong>thang đo chuẩn quốc tế</strong> để đánh giá trình độ đọc</p>
                </div>
                <div class="problem-item">
                    <span>🎯</span>
                    <p>Chưa đáp ứng <strong>Đề án 2371/QĐ-TTg</strong> về tiếng Anh trong trường học</p>
                </div>
            </div>
        </div>

        <!-- Arrow down -->
        <div class="solutions-arrow">
            <svg width="40" height="40" viewBox="0 0 40 40"><path d="M20 8v20M12 22l8 8 8-8" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>
        </div>

        <!-- Solution cards - 3 pillars -->
        <div class="solutions-pillars">
            <div class="pillar-card">
                <div class="pillar-number">01</div>
                <div class="pillar-header trophy-accent">
                    <h3>Xây Nền Tảng Vững Chắc</h3>
                    <span class="pillar-platform">Trophy9 | Mầm Non → THCS</span>
                </div>
                <div class="pillar-body">
                    <ul>
                        <li><strong>Phonics → Fluency:</strong> 54 giai đoạn có hệ thống, từ âm thanh đến đọc trôi chảy</li>
                        <li><strong>4 kỹ năng đồng thời:</strong> Nghe - Nói - Đọc - Viết qua 9 hoạt động tương tác</li>
                        <li><strong>198 Leveled Readers</strong> theo chuẩn CCSS Mỹ + 54 Workbooks</li>
                        <li><strong>Blended Learning:</strong> Sách giấy Benchmark Education + E-Learning online</li>
                    </ul>
                    <div class="pillar-result">
                        <span class="result-label">Kết quả:</span>
                        <span class="result-value">CEFR A1 → B1 | Lexile 200L → 1000L</span>
                    </div>
                </div>
            </div>

            <div class="pillar-card pillar-bridge">
                <div class="pillar-number">02</div>
                <div class="pillar-header bridge-accent">
                    <h3>Chuyển Tiếp Liền Mạch</h3>
                    <span class="pillar-platform">LevelSet Assessment</span>
                </div>
                <div class="pillar-body">
                    <ul>
                        <li><strong>Đánh giá LevelSet:</strong> Xác định chính xác chỉ số Lexile khi chuyển từ Trophy9 sang Achieve3000</li>
                        <li><strong>Không gián đoạn:</strong> Học sinh tiếp tục đúng trình độ, không mất thời gian học lại</li>
                        <li><strong>Dữ liệu liên thông:</strong> Giáo viên theo dõi hành trình từ Mầm Non đến Đại Học trên 1 hệ thống</li>
                    </ul>
                    <div class="pillar-result">
                        <span class="result-label">Điểm mạnh:</span>
                        <span class="result-value">1 lộ trình - 1 hệ thống - Liên cấp</span>
                    </div>
                </div>
            </div>

            <div class="pillar-card">
                <div class="pillar-number">03</div>
                <div class="pillar-header achieve-accent">
                    <h3>Nâng Cao Học Thuật & IELTS</h3>
                    <span class="pillar-platform">Achieve3000 | THPT → Đại Học</span>
                </div>
                <div class="pillar-body">
                    <ul>
                        <li><strong>Cá nhân hóa AI:</strong> 12 cấp độ Lexile tự động thích ứng theo trình độ từng học sinh</li>
                        <li><strong>Đa lĩnh vực:</strong> ELA, Khoa Học, Xã Hội - xây dựng kiến thức nền cho IELTS Academic</li>
                        <li><strong>Nghiên cứu 40+ năm:</strong> Học sinh tăng trưởng gấp 2.1 - 4.2 lần so với kỳ vọng</li>
                        <li><strong>Career Center:</strong> Kết nối đọc hiểu với định hướng nghề nghiệp</li>
                    </ul>
                    <div class="pillar-result">
                        <span class="result-label">Kết quả:</span>
                        <span class="result-value">IELTS 5.0 → 8.0+ | Lexile 1000L → 1400L+</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Why this combination - key differentiators -->
        <div class="solutions-why">
            <h3>Lợi Thế Khi Kết Hợp 2 Nền Tảng</h3>
            <div class="why-grid">
                <div class="why-card">
                    <div class="why-icon">🏫</div>
                    <h4>Liên Cấp Duy Nhất</h4>
                    <p>Lộ trình liền mạch từ 3 tuổi đến Đại Học. Không cần thay đổi nền tảng giữa chừng, tiết kiệm chi phí đào tạo lại.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">📐</div>
                    <h4>Chuẩn Quốc Tế Kép</h4>
                    <p><strong>CCSS</strong> đảm bảo nội dung đúng chuẩn Mỹ. <strong>Lexile</strong> đo lường trình độ đọc chính xác. Hai chuẩn bổ sung hoàn hảo.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">🤖</div>
                    <h4>Từ GV Dẫn Dắt → AI Thích Ứng</h4>
                    <p>Trophy9: GV chủ đạo, online hỗ trợ. Achieve3000: AI cá nhân hóa, GV giám sát dữ liệu. Phản ánh sự trưởng thành tự nhiên.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">📋</div>
                    <h4>Đáp Ứng Đề Án 2371/QĐ-TTg</h4>
                    <p>Giải pháp sẵn sàng cho "Đưa tiếng Anh thành ngôn ngữ thứ hai trong trường học 2025-2035". Triển khai nhanh, đo lường được.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">📊</div>
                    <h4>Dữ Liệu Minh Bạch</h4>
                    <p>Dashboard realtime cho giáo viên, ban giám hiệu, phụ huynh. Lexile Growth Report chứng minh hiệu quả đầu tư.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">💰</div>
                    <h4>ROI Rõ Ràng</h4>
                    <p>Achieve3000 chứng minh: học sinh sử dụng đúng cách tăng trưởng <strong>gấp 2-4 lần</strong>. Đo được = Chứng minh được = Đầu tư đúng.</p>
                </div>
            </div>
        </div>

        <!-- Social proof / stats -->
        <div class="solutions-proof">
            <div class="proof-stat">
                <span class="proof-number">2.1-4.2x</span>
                <span class="proof-label">Tăng trưởng Lexile so với kỳ vọng</span>
                <span class="proof-source">Nghiên cứu Achieve3000</span>
            </div>
            <div class="proof-stat">
                <span class="proof-number">198+54</span>
                <span class="proof-label">Readers & Workbooks theo chuẩn CCSS</span>
                <span class="proof-source">Benchmark Education</span>
            </div>
            <div class="proof-stat">
                <span class="proof-number">40+</span>
                <span class="proof-label">Năm nghiên cứu khoa học đọc hiểu</span>
                <span class="proof-source">McGraw Hill</span>
            </div>
            <div class="proof-stat">
                <span class="proof-number">3→18+</span>
                <span class="proof-label">Tuổi - Lộ trình liên cấp hoàn chỉnh</span>
                <span class="proof-source">Reading Pathway</span>
            </div>
        </div>
    </div>
</section>

<!-- B2B Schools Section - Implementation Details -->
<section class="section section-b2b" id="schools">
    <div class="container">
        <div class="section-header">
            <span class="section-tag b2b-tag"><%= g('b2b','tag') %></span>
            <h2><%= g('b2b','heading') %></h2>
            <p><%= g('b2b','description') %></p>
        </div>
        <div class="b2b-grid">
            <% for (let i = 1; i <= 4; i++) { %>
            <div class="b2b-card">
                <div class="b2b-icon">
                    <% const b2bColors = ['#E8F4FD','#FFF1F0','#F0FDF4','#F5F3FF']; %>
                    <% const b2bFills = ['#0056A6','#C8372D','#10B981','#7C3AED']; %>
                    <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="10" fill="<%= b2bColors[i-1] %>"/><circle cx="20" cy="20" r="8" fill="<%= b2bFills[i-1] %>"/></svg>
                </div>
                <h3><%= g('b2b','card_'+i+'_title') %></h3>
                <p><%= g('b2b','card_'+i+'_desc') %></p>
                <ul class="b2b-features">
                    <% list('b2b','card_'+i+'_features').forEach(f => { %>
                    <li><%= f %></li>
                    <% }); %>
                </ul>
            </div>
            <% } %>
        </div>

        <div class="testing-framework">
            <h3><%= g('b2b','testing_heading') %></h3>
            <div class="testing-timeline">
                <% const testColors = ['placement','module','midterm','final']; %>
                <% for (let i = 1; i <= 4; i++) { %>
                <div class="test-step">
                    <div class="test-icon <%= testColors[i-1] %>"><%= ['P','M','G','F'][i-1] %></div>
                    <div class="test-info">
                        <h4><%= g('b2b','test_'+i+'_title') %></h4>
                        <p><%= g('b2b','test_'+i+'_time') %></p>
                        <span class="test-desc"><%= g('b2b','test_'+i+'_desc') %></span>
                    </div>
                </div>
                <% if (i < 4) { %><div class="test-arrow">→</div><% } %>
                <% } %>
            </div>
        </div>

        <div class="b2b-cta">
            <p><%= g('b2b','cta_text') %></p>
            <a href="#contact" class="btn btn-primary btn-lg"><%= g('b2b','cta_button') %></a>
        </div>
    </div>
</section>

<!-- Testimonials / Social Proof -->
<section class="section section-testimonials">
    <div class="container">
