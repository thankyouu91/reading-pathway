    <meta property="og:url" content="<%= typeof siteUrl !== 'undefined' ? siteUrl : 'https://reading-pathway-production.up.railway.app' %>">
    <meta property="og:title" content="Reading Pathway | Chương Trình Đọc Hiểu Toàn Diện - Trophy9 & Achieve3000">
    <meta property="og:description" content="Lộ trình đọc hiểu & Pre-IELTS từ Mầm Non đến Đại Học. 54 cấp độ, 198 Readers, 9 hoạt động tương tác theo chuẩn Mỹ CCSS & Lexile.">
