<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> | Reading Pathway</title>
    <meta name="description" content="<%= pageDesc %>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/premium.css">
    <link rel="stylesheet" href="/blog.css">
    <link rel="stylesheet" href="/support.css">
</head>
<body>
    <nav class="blog-nav">
        <div class="container blog-nav-inner">
            <a href="/" class="logo"><span>📖</span> Reading <strong>Pathway</strong></a>
            <div class="blog-nav-links">
                <a href="/">Trang Chủ</a>
                <a href="/blog">Blog</a>
                <a href="/#contact">Liên Hệ</a>
            </div>
        </div>
    </nav>

    <header class="blog-header support-hero">
        <canvas id="heroCanvas" class="hero-canvas"></canvas>
        <div class="container" style="position:relative;z-index:2;">
            <h1><%= pageTitle %></h1>
            <p><%= pageDesc %></p>
        </div>
    </header>

    <script>
    (function() {
      const canvas = document.getElementById('heroCanvas');
      const ctx = canvas.getContext('2d');

      function resize() {
        const header = canvas.parentElement;
        canvas.width  = header.offsetWidth;
        canvas.height = header.offsetHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // Education-themed symbols
      const symbols = ['📚','✏️','📖','🔤','A','B','C','α','β','★','?','!',
                       '1','2','3','∑','≈','%','📝','🎓','Aa','Bb','Cc'];

      const particles = Array.from({ length: 40 }, () => ({
        x: Math.random() * 1,
        y: Math.random() * 1,
        symbol: symbols[Math.floor(Math.random() * symbols.length)],
        size: Math.random() * 14 + 10,
        opacity: Math.random() * 0.18 + 0.06,
        speedY: Math.random() * 0.12 + 0.04,
        speedX: (Math.random() - 0.5) * 0.08,
        rotate: Math.random() * Math.PI * 2,
        rotateSpeed: (Math.random() - 0.5) * 0.6,
        phase: Math.random() * Math.PI * 2,
      }));

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const t = Date.now() / 1000;

        particles.forEach(p => {
          const x = ((p.x * canvas.width + p.speedX * t * 60) % canvas.width + canvas.width) % canvas.width;
          const y = ((p.y * canvas.height - p.speedY * t * 30) % canvas.height + canvas.height) % canvas.height;
          const alpha = p.opacity * (0.7 + Math.sin(t * 0.7 + p.phase) * 0.3);
          const angle = p.rotate + p.rotateSpeed * t;

          ctx.save();
          ctx.translate(x, y);
          ctx.rotate(angle);
          ctx.globalAlpha = alpha;
          ctx.font = `${p.size}px Inter, sans-serif`;
          ctx.fillStyle = 'rgba(180,220,255,1)';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(p.symbol, 0, 0);
          ctx.restore();
        });
        requestAnimationFrame(draw);
      }
      draw();
    })();
    </script>

    <main class="support-main">
        <div class="container support-container">
            <aside class="support-sidebar">
                <nav class="support-nav">
                    <a href="/ho-tro/faq" class="<%= page === 'faq' ? 'active' : '' %>">
                        <span>❓</span> FAQ
                    </a>
                    <a href="/ho-tro/huong-dan" class="<%= page === 'guide' ? 'active' : '' %>">
                        <span>📘</span> Hướng Dẫn
                    </a>
                    <a href="/ho-tro/chinh-sach-bao-mat" class="<%= page === 'privacy' ? 'active' : '' %>">
                        <span>🔒</span> Bảo Mật
                    </a>
                    <a href="/ho-tro/dieu-khoan" class="<%= page === 'terms' ? 'active' : '' %>">
                        <span>📄</span> Điều Khoản
                    </a>
                </nav>
                <div class="support-contact-box">
                    <h4>Cần hỗ trợ thêm?</h4>
                    <p>Đội ngũ của chúng tôi sẵn sàng giải đáp mọi thắc mắc.</p>
                    <a href="/#contact" class="support-cta-btn">Liên Hệ Ngay</a>
                </div>
            </aside>

            <article class="support-content">
