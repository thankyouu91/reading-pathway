<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> | Reading Pathway</title>
    <meta name="description" content="<%= pageDesc %>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/premium.css">
    <link rel="stylesheet" href="/blog.css">
    <link rel="stylesheet" href="/support.css">
</head>
<body>
    <nav class="blog-nav">
        <div class="container blog-nav-inner">
            <a href="/" class="logo"><span>📖</span> Reading <strong>Pathway</strong></a>
            <div class="blog-nav-links">
                <a href="/">Trang Chủ</a>
                <a href="/blog">Blog</a>
                <a href="/#contact">Liên Hệ</a>
            </div>
        </div>
    </nav>

    <header class="blog-header support-hero">
        <canvas id="heroCanvas" class="hero-canvas"></canvas>
        <div class="container" style="position:relative;z-index:2;">
            <h1><%= pageTitle %></h1>
            <p><%= pageDesc %></p>
        </div>
    </header>

    <script>
    (function() {
      const canvas = document.getElementById('heroCanvas');
      const ctx = canvas.getContext('2d');

      function resize() {
        const header = canvas.parentElement;
        canvas.width  = header.offsetWidth;
        canvas.height = header.offsetHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // More shapes, larger sizes to fill the full banner
      const shapes = Array.from({ length: 50 }, () => ({
        x: Math.random(),
        y: Math.random(),
        r: Math.random() * 36 + 5,
        opacity: Math.random() * 0.15 + 0.03,
        speed: Math.random() * 0.15 + 0.04,
        dx: (Math.random() - 0.5) * 0.25,
        type: Math.floor(Math.random() * 3),
        phase: Math.random() * Math.PI * 2,
      }));

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const t = Date.now() / 1000;
        shapes.forEach(s => {
          const x = ((s.x * canvas.width + s.dx * t * 40) % canvas.width + canvas.width) % canvas.width;
          const y = ((s.y * canvas.height - s.speed * t * 18) % canvas.height + canvas.height) % canvas.height;
          const pulse = 1 + Math.sin(t * 0.8 + s.phase) * 0.12;
          const alpha = s.opacity * (0.85 + Math.sin(t * 0.5 + s.phase) * 0.15);

          ctx.beginPath();
          if (s.type === 0) {
            ctx.arc(x, y, s.r * pulse, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(110,175,255,${alpha})`;
            ctx.fill();
          } else if (s.type === 1) {
            ctx.arc(x, y, s.r * pulse, 0, Math.PI * 2);
            ctx.strokeStyle = `rgba(150,205,255,${alpha * 1.6})`;
            ctx.lineWidth = 1.5;
            ctx.stroke();
          } else {
            ctx.arc(x, y, s.r * 0.28 * pulse, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(210,235,255,${alpha * 2.2})`;
            ctx.fill();
          }
        });
        requestAnimationFrame(draw);
      }
      draw();
    })();
    </script>

    <main class="support-main">
        <div class="container support-container">
            <aside class="support-sidebar">
                <nav class="support-nav">
                    <a href="/ho-tro/faq" class="<%= page === 'faq' ? 'active' : '' %>">
                        <span>❓</span> FAQ
                    </a>
                    <a href="/ho-tro/huong-dan" class="<%= page === 'guide' ? 'active' : '' %>">
                        <span>📘</span> Hướng Dẫn
                    </a>
                    <a href="/ho-tro/chinh-sach-bao-mat" class="<%= page === 'privacy' ? 'active' : '' %>">
                        <span>🔒</span> Bảo Mật
                    </a>
                    <a href="/ho-tro/dieu-khoan" class="<%= page === 'terms' ? 'active' : '' %>">
                        <span>📄</span> Điều Khoản
                    </a>
                </nav>
                <div class="support-contact-box">
                    <h4>Cần hỗ trợ thêm?</h4>
                    <p>Đội ngũ của chúng tôi sẵn sàng giải đáp mọi thắc mắc.</p>
                    <a href="/#contact" class="support-cta-btn">Liên Hệ Ngay</a>
                </div>
            </aside>

            <article class="support-content">
